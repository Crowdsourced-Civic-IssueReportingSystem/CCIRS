# Database connection string (PostgreSQL + PostGIS-ready)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ccirs?schema=public"

# JWT secrets (REQUIRED - change these in production!)
JWT_ACCESS_SECRET="dev-access-secret-change-in-production"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-production"

# JWT expirations
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Server configuration
PORT=3000

# CORS origin (set to your frontend origin, e.g., http://localhost:3000 or http://localhost:5173)
CORS_ORIGIN="*"

# Firebase Admin (set either Strategy A or Strategy B)
# Strategy A: full JSON service account in one variable
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Strategy B: discrete credential fields
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Firebase Web SDK configuration (used for ID token verification in middleware)
FIREBASE_WEB_API_KEY=""
FIREBASE_WEB_AUTH_DOMAIN=""
FIREBASE_WEB_PROJECT_ID=""
FIREBASE_WEB_STORAGE_BUCKET=""
FIREBASE_WEB_MESSAGING_SENDER_ID=""
FIREBASE_WEB_APP_ID=""

# Firebase behavior flags
FIREBASE_ENABLE_LOCAL_AUTH="0"
FIREBASE_USE_LOCAL_STORE="0"
# Optional: set to "1" to keep proxy variables unchanged at startup
DISABLE_PROXY_ENV_GUARD="0"
# Optional: comma-separated admin emails for local auth mode
ADMIN_EMAILS=""

# Node environment
NODE_ENV="development"
