# Database connection string (PostgreSQL + PostGIS-ready)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ccirs?schema=public"

# JWT secrets (REQUIRED - change these in production!)
JWT_ACCESS_SECRET="my_dev_access_secret_key_change_in_production"
JWT_REFRESH_SECRET="my_dev_refresh_secret_key_change_in_production"

# JWT expirations
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Server configuration
PORT=3000

# CORS origin (allows frontend to communicate with backend)
CORS_ORIGIN="*"

# Firebase Admin (set either Strategy A or Strategy B)
FIREBASE_SERVICE_ACCOUNT_JSON=""
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Node environment
NODE_ENV="development"
